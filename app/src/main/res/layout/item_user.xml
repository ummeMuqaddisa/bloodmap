<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top Header: Image, Name, and Blood Group -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivUserProfile"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginEnd="12dp"
                android:scaleType="centerCrop"
                android:src="@android:color/darker_gray"
                app:shapeAppearanceOverlay="@style/CircleAppearance" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/ivUserProfile"
                android:layout_toStartOf="@id/tvUserBloodGroup"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvUserName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#212121"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvUserEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#757575"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvUserBloodGroup"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:background="#D32F2F"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- Status Badges Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvAdminBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="#E3F2FD"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:text="System Admin"
                android:textColor="#1976D2"
                android:textSize="11sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvUserStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="#E8F5E9"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:text="ACTIVE"
                android:textColor="#2E7D32"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvAvailabilityBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="#FFF3E0"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:text="Available"
                android:textColor="#E65100"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="12dp"
            android:background="#EEEEEE" />

        <!-- Info Grid -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="4">

            <!-- Contact & Location -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_marginBottom="8dp"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Contact &amp; Location"
                    android:textColor="#9E9E9E"
                    android:textSize="10sp"
                    android:textAllCaps="true" />
                <TextView
                    android:id="@+id/tvUserContact"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#424242"
                    android:textSize="13sp" />
                <TextView
                    android:id="@+id/tvUserLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#424242"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Subscription & CreatedAt -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_marginBottom="8dp"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Account Details"
                    android:textColor="#9E9E9E"
                    android:textSize="10sp"
                    android:textAllCaps="true" />
                <TextView
                    android:id="@+id/tvSubscriptionPlan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#1976D2"
                    android:textSize="13sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvCreatedAt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#616161"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Stats -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_marginBottom="8dp"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Activity Statistics"
                    android:textColor="#9E9E9E"
                    android:textSize="10sp"
                    android:textAllCaps="true" />
                <TextView
                    android:id="@+id/tvUserDonations"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#2E7D32"
                    android:textSize="13sp" />
                <TextView
                    android:id="@+id/tvUserRequests"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#D32F2F"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Donation Cycles -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_marginBottom="8dp"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Donation Cycle"
                    android:textColor="#9E9E9E"
                    android:textSize="10sp"
                    android:textAllCaps="true" />
                <TextView
                    android:id="@+id/tvLastDonationDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#424242"
                    android:textSize="12sp" />
                <TextView
                    android:id="@+id/tvNextEligibleDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#D32F2F"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </GridLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>

