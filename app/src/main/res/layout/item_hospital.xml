<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Blood Bank Badge + Edit Button Row -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tvBloodBankStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_blue"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:text="BLOOD BANK AVAILABLE"
                android:textColor="#4A6CF7"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.04"
                android:layout_centerVertical="true"
                android:visibility="gone" />

            <ImageButton
                android:id="@+id/btnEditHospital"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_alignParentEnd="true"
                android:background="@drawable/bg_circle_white"
                android:src="@drawable/ic_edit_bold"
                android:padding="10dp"
                android:elevation="2dp"
                android:visibility="gone" />
        </RelativeLayout>

        <!-- Hospital Name -->
        <TextView
            android:id="@+id/tvHospitalName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dhaka Medical College Hospital"
            android:textColor="#800000"
            android:textSize="24sp"
            android:textStyle="bold"
            android:lineSpacingMultiplier="1.1"
            android:layout_marginBottom="16dp" />

        <!-- Address Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_admin_location_bold"
                app:tint="#1A1A1A" />
            <TextView
                android:id="@+id/tvHospitalAddress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Secretariat Road, Dhaka 1000"
                android:textColor="#1A1A1A"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Phone Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_phone_bold"
                app:tint="#1A1A1A" />
            <TextView
                android:id="@+id/tvHospitalContact"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="+880 2-55165088"
                android:textColor="#1A1A1A"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F0F0F0"
            android:layout_marginBottom="16dp" />

        <!-- Facilities Label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FACILITIES"
            android:textColor="#BDBDBD"
            android:textSize="9sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:layout_marginBottom="8dp" />

        <!-- Facilities Text -->
        <TextView
            android:id="@+id/tvFacilities"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_facility_tag"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:text="Emergency, ICU, Surgery"
            android:textColor="#424242"
            android:textSize="13sp"
            android:layout_marginBottom="20dp"
            android:visibility="gone" />

        <!-- Bottom: Coordinates + Action Buttons -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Coordinates (left) -->
            <TextView
                android:id="@+id/tvCoordinates"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:textColor="#BDBDBD"
                android:textSize="10sp"
                android:lineSpacingExtra="2dp" />

            <!-- Action Buttons (right) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Call Button -->
                <LinearLayout
                    android:id="@+id/btnCallHospital"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:layout_marginEnd="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_phone_bold"
                        app:tint="#1A1A1A" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="CALL"
                        android:textColor="#1A1A1A"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.04" />
                </LinearLayout>

                <!-- Navigate Button -->
                <LinearLayout
                    android:id="@+id/btnNavigateHospital"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_button_direction"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:orientation="horizontal"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground">
                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_arrow_direction" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="NAVIGATE"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.04" />
                </LinearLayout>

            </LinearLayout>
        </RelativeLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
