<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fitsSystemWindows="true">

    <!-- Top Bar -->
    <RelativeLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/back_button"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_arrow_back"
            android:padding="4dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            app:tint="#1A1A1A" />

        <TextView
            android:id="@+id/tvBankFormTitle_Secondary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="ST. JUDE CENTRAL"
            android:textColor="#800000"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/toolbar"
        android:clipToPadding="false"
        android:paddingBottom="40dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="12dp">

            <!-- Header -->
            <TextView
                android:id="@+id/tvBankFormTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Edit Blood Bank"
                android:textColor="#1A1A1A"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Update facility details and inventory levels."
                android:textColor="#757575"
                android:textSize="14sp" />

            <!-- Form Fields -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="32dp">

                <!-- Name -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FACILITY NAME"
                    android:textColor="#800000"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />
                <EditText
                    android:id="@+id/etBankName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_input_minimal"
                    android:hint="Facility Full Name"
                    android:paddingVertical="12dp"
                    android:textColor="#1A1A1A"
                    android:textSize="16sp" />

                <!-- Contact -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="CONTACT"
                    android:textColor="#800000"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />
                <EditText
                    android:id="@+id/etBankPhone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_input_minimal"
                    android:hint="+1 (XXX) XXX-XXXX"
                    android:inputType="phone"
                    android:paddingVertical="12dp"
                    android:textColor="#1A1A1A"
                    android:textSize="16sp" />

                <!-- Location -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="LOCATION"
                    android:textColor="#800000"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />
                <EditText
                    android:id="@+id/etBankAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_input_minimal"
                    android:hint="City or Full Address"
                    android:paddingVertical="12dp"
                    android:textColor="#1A1A1A"
                    android:textSize="16sp" />

                <!-- Geographic Details (Minimalist row for functionality) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">
                    <EditText
                        android:id="@+id/etLat"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="Latitude"
                        android:inputType="numberDecimal|numberSigned"
                        android:textColor="#BDBDBD"
                        android:textSize="11sp" />
                    <EditText
                        android:id="@+id/etLon"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="Longitude"
                        android:inputType="numberDecimal|numberSigned"
                        android:textColor="#BDBDBD"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Inventory Units Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:orientation="horizontal"
                android:gravity="bottom">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Inventory Units"
                    android:textColor="#1A1A1A"
                    android:textSize="18sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="(ML)"
                    android:textColor="#757575"
                    android:textSize="12sp"
                    android:layout_marginBottom="2dp" />
            </LinearLayout>

            <!-- Inventory Grid -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:columnCount="2"
                android:useDefaultMargins="false">

                <!-- A+ -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_margin="8dp" android:background="@drawable/bg_inventory_card" android:orientation="vertical" android:padding="16dp" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="A+" android:textColor="#800000" android:textSize="16sp" android:textStyle="bold" />
                    <EditText android:id="@+id/etAPos" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:background="@drawable/bg_field_input" android:gravity="center" android:inputType="number" android:padding="8dp" android:text="0" android:textColor="#1A1A1A" android:textSize="14sp" android:textStyle="bold" />
                </LinearLayout>

                <!-- A- -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_margin="8dp" android:background="@drawable/bg_inventory_card" android:orientation="vertical" android:padding="16dp" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="A-" android:textColor="#800000" android:textSize="16sp" android:textStyle="bold" />
                    <EditText android:id="@+id/etANeg" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:background="@drawable/bg_field_input" android:gravity="center" android:inputType="number" android:padding="8dp" android:text="0" android:textColor="#1A1A1A" android:textSize="14sp" android:textStyle="bold" />
                </LinearLayout>

                <!-- B+ -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_margin="8dp" android:background="@drawable/bg_inventory_card" android:orientation="vertical" android:padding="16dp" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="B+" android:textColor="#800000" android:textSize="16sp" android:textStyle="bold" />
                    <EditText android:id="@+id/etBPos" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:background="@drawable/bg_field_input" android:gravity="center" android:inputType="number" android:padding="8dp" android:text="0" android:textColor="#1A1A1A" android:textSize="14sp" android:textStyle="bold" />
                </LinearLayout>

                <!-- B- -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_margin="8dp" android:background="@drawable/bg_inventory_card" android:orientation="vertical" android:padding="16dp" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="B-" android:textColor="#800000" android:textSize="16sp" android:textStyle="bold" />
                    <EditText android:id="@+id/etBNeg" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:background="@drawable/bg_field_input" android:gravity="center" android:inputType="number" android:padding="8dp" android:text="0" android:textColor="#1A1A1A" android:textSize="14sp" android:textStyle="bold" />
                </LinearLayout>

                <!-- O+ -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_margin="8dp" android:background="@drawable/bg_inventory_card" android:orientation="vertical" android:padding="16dp" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="O+" android:textColor="#800000" android:textSize="16sp" android:textStyle="bold" />
                    <EditText android:id="@+id/etOPos" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:background="@drawable/bg_field_input" android:gravity="center" android:inputType="number" android:padding="8dp" android:text="0" android:textColor="#1A1A1A" android:textSize="14sp" android:textStyle="bold" />
                </LinearLayout>

                <!-- O- -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_margin="8dp" android:background="@drawable/bg_inventory_card" android:orientation="vertical" android:padding="16dp" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="O-" android:textColor="#800000" android:textSize="16sp" android:textStyle="bold" />
                    <EditText android:id="@+id/etONeg" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:background="@drawable/bg_field_input" android:gravity="center" android:inputType="number" android:padding="8dp" android:text="0" android:textColor="#1A1A1A" android:textSize="14sp" android:textStyle="bold" />
                </LinearLayout>

                <!-- AB+ -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_margin="8dp" android:background="@drawable/bg_inventory_card" android:orientation="vertical" android:padding="16dp" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AB+" android:textColor="#800000" android:textSize="16sp" android:textStyle="bold" />
                    <EditText android:id="@+id/etABPos" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:background="@drawable/bg_field_input" android:gravity="center" android:inputType="number" android:padding="8dp" android:text="0" android:textColor="#1A1A1A" android:textSize="14sp" android:textStyle="bold" />
                </LinearLayout>

                <!-- AB- -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_margin="8dp" android:background="@drawable/bg_inventory_card" android:orientation="vertical" android:padding="16dp" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AB-" android:textColor="#800000" android:textSize="16sp" android:textStyle="bold" />
                    <EditText android:id="@+id/etABNeg" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:background="@drawable/bg_field_input" android:gravity="center" android:inputType="number" android:padding="8dp" android:text="0" android:textColor="#1A1A1A" android:textSize="14sp" android:textStyle="bold" />
                </LinearLayout>

            </GridLayout>

            <!-- 24H Toggle -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:text="24-Hour Operations"
                    android:textColor="#1A1A1A"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/sw24Hours"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    app:useMaterialThemeColors="false"
                    app:thumbTint="#800000"
                    app:trackTint="#E0E0E0" />
            </RelativeLayout>

            <!-- Action Buttons -->
            <Button
                android:id="@+id/btnSaveBank"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="40dp"
                android:backgroundTint="#800000"
                android:text="Update Information"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="12dp" />

            <TextView
                android:id="@+id/btnDiscardChanges"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_gravity="center"
                android:text="DISCARD CHANGES"
                android:textColor="#1A1A1A"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:padding="8dp"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"/>

        </LinearLayout>
    </ScrollView>
</RelativeLayout>
