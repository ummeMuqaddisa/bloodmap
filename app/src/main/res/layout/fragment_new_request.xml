<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">
        <!-- ── Patient Details Card ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- PATIENT NAME -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PATIENT NAME"
                    android:textColor="#999999"
                    android:textSize="10sp"
                    android:letterSpacing="0.08"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/etPatientName"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Enter patient's full name"
                    android:textColorHint="#BBBBBB"
                    android:inputType="textPersonName"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/bg_field_input"
                    android:textColor="#222222"
                    android:textSize="14sp"
                    android:layout_marginBottom="14dp" />

                <!-- AGE & GENDER row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="14dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AGE"
                            android:textColor="#999999"
                            android:textSize="10sp"
                            android:letterSpacing="0.08"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginBottom="6dp" />

                        <EditText
                            android:id="@+id/etPatientAge"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:hint="e.g. 34"
                            android:textColorHint="#BBBBBB"
                            android:inputType="number"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:background="@drawable/bg_field_input"
                            android:textColor="#222222"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="GENDER"
                            android:textColor="#999999"
                            android:textSize="10sp"
                            android:letterSpacing="0.08"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginBottom="6dp" />

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_field_input">

                            <Spinner
                                android:id="@+id/spinnerPatientGender"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp" />
                        </FrameLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- BLOOD GROUP & UNITS NEEDED row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="14dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="BLOOD GROUP"
                            android:textColor="#999999"
                            android:textSize="10sp"
                            android:letterSpacing="0.08"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginBottom="6dp" />

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_field_input">

                            <Spinner
                                android:id="@+id/spinnerBloodGroup"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp" />
                        </FrameLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="UNITS NEEDED"
                            android:textColor="#999999"
                            android:textSize="10sp"
                            android:letterSpacing="0.08"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginBottom="6dp" />

                        <EditText
                            android:id="@+id/etUnitsRequired"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:hint="e.g. 2"
                            android:textColorHint="#BBBBBB"
                            android:inputType="number"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:background="@drawable/bg_field_input"
                            android:textColor="#222222"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- URGENCY LEVEL -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="URGENCY LEVEL"
                    android:textColor="#999999"
                    android:textSize="10sp"
                    android:letterSpacing="0.08"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="6dp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_field_input"
                    android:layout_marginBottom="14dp">

                    <Spinner
                        android:id="@+id/spinnerUrgencyLevel"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp" />
                </FrameLayout>

                <!-- DATE NEEDED & TIME NEEDED row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="14dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DATE NEEDED"
                            android:textColor="#999999"
                            android:textSize="10sp"
                            android:letterSpacing="0.08"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginBottom="6dp" />

                        <EditText
                            android:id="@+id/etNeededByTime"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:hint="mm/dd/yyyy"
                            android:textColorHint="#BBBBBB"
                            android:focusable="false"
                            android:clickable="true"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:background="@drawable/bg_field_input"
                            android:textColor="#222222"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TIME NEEDED"
                            android:textColor="#999999"
                            android:textSize="10sp"
                            android:letterSpacing="0.08"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginBottom="6dp" />

                        <EditText
                            android:id="@+id/etTimeNeeded"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:hint="- : - -"
                            android:textColorHint="#BBBBBB"
                            android:focusable="false"
                            android:clickable="true"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:background="@drawable/bg_field_input"
                            android:textColor="#222222"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- REASON FOR REQUEST -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="REASON FOR REQUEST"
                    android:textColor="#999999"
                    android:textSize="10sp"
                    android:letterSpacing="0.08"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/etReason"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="e.g. Surgery, Accident, Anemia"
                    android:textColorHint="#BBBBBB"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/bg_field_input"
                    android:textColor="#222222"
                    android:textSize="14sp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Location & Contact Card ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Section header -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LOCATION &amp; CONTACT"
                    android:textColor="#7C0C0F"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:fontFamily="sans-serif-medium"
                    android:textStyle="bold"
                    android:layout_marginBottom="14dp" />

                <!-- HOSPITAL NAME -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HOSPITAL NAME"
                    android:textColor="#999999"
                    android:textSize="10sp"
                    android:letterSpacing="0.08"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="6dp" />

                <AutoCompleteTextView
                    android:id="@+id/etHospitalDetails"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Enter hospital name"
                    android:textColorHint="#BBBBBB"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/bg_field_input"
                    android:textColor="#222222"
                    android:textSize="14sp"
                    android:completionThreshold="1"
                    android:inputType="textPersonName"
                    android:layout_marginBottom="14dp" />

                <!-- AREA / CITY -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AREA / CITY"
                    android:textColor="#999999"
                    android:textSize="10sp"
                    android:letterSpacing="0.08"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="6dp" />

                <AutoCompleteTextView
                    android:id="@+id/etArea"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Enter specific area or city"
                    android:textColorHint="#BBBBBB"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/bg_field_input"
                    android:textColor="#222222"
                    android:textSize="14sp"
                    android:completionThreshold="1"
                    android:inputType="text"
                    android:layout_marginBottom="14dp" />

                <!-- CONTACT NUMBER -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CONTACT NUMBER"
                    android:textColor="#999999"
                    android:textSize="10sp"
                    android:letterSpacing="0.08"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/etContactNumber"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Enter phone number"
                    android:textColorHint="#BBBBBB"
                    android:inputType="phone"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/bg_field_input"
                    android:textColor="#222222"
                    android:textSize="14sp"
                    android:layout_marginBottom="14dp" />

                <!-- ADDITIONAL NOTES -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ADDITIONAL NOTES (OPTIONAL)"
                    android:textColor="#999999"
                    android:textSize="10sp"
                    android:letterSpacing="0.08"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/etNotes"
                    android:layout_width="match_parent"
                    android:layout_height="96dp"
                    android:hint="Any specific instructions or details..."
                    android:textColorHint="#BBBBBB"
                    android:gravity="top|start"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:background="@drawable/bg_field_input"
                    android:textColor="#222222"
                    android:textSize="14sp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Submit Button ── -->
        <Button
            android:id="@+id/btnSubmitRequest"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="SUBMIT REQUEST"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.05"
            android:backgroundTint="#A30F24"
            android:stateListAnimator="@null"
            android:layout_marginBottom="24dp" />

    </LinearLayout>
</ScrollView>
