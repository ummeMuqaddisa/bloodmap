<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/admin_drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F5F5F5">

        <LinearLayout
            android:id="@+id/top_appbar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_alignParentTop="true"
            android:background="#D11A2A"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:elevation="4dp">

            <ImageView
                android:id="@+id/menu_icon"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                app:tint="#FFFFFF" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:text="Admin Dashboard"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/top_appbar"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="System Overview"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="16dp"/>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:useDefaultMargins="true"
                android:alignmentMode="alignMargins"
                android:columnOrderPreserved="false">

                <!-- Total Users Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total Users"
                            android:textSize="14sp"
                            android:textColor="#555555"
                            android:layout_marginBottom="4dp"/>
                        <TextView
                            android:id="@+id/tvUsersCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="..."
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="#D11A2A"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Available Donors Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Available Donors"
                            android:textSize="14sp"
                            android:textColor="#555555"
                            android:layout_marginBottom="4dp"/>
                        <TextView
                            android:id="@+id/tvAvailableDonorsCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="..."
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="#2E7D32"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Active Requests Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Active Requests"
                            android:textSize="14sp"
                            android:textColor="#555555"
                            android:layout_marginBottom="4dp"/>
                        <TextView
                            android:id="@+id/tvActiveRequestsCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="..."
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="#1565C0"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Completed Requests Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Completed Reqs"
                            android:textSize="14sp"
                            android:textColor="#555555"
                            android:layout_marginBottom="4dp"/>
                        <TextView
                            android:id="@+id/tvCompletedRequestsCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="..."
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="#424242"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Total Hospitals Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total Hospitals"
                            android:textSize="14sp"
                            android:textColor="#555555"
                            android:layout_marginBottom="4dp"/>
                        <TextView
                            android:id="@+id/tvHospitalsCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="..."
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="#D11A2A"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Total Blood Banks Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Blood Banks"
                            android:textSize="14sp"
                            android:textColor="#555555"
                            android:layout_marginBottom="4dp"/>
                        <TextView
                            android:id="@+id/tvBloodBanksCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="..."
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="#D11A2A"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- System Locations Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="2dp">

                </androidx.cardview.widget.CardView>

            </GridLayout>

        </LinearLayout>

    </RelativeLayout>

    <LinearLayout
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#FFFFFF"
        android:clickable="true"
        android:focusable="true"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="#D11A2A"
            android:gravity="bottom"
            android:orientation="vertical"
            android:padding="20dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Admin Center"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/menu_show_users"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:text="Show All Users"
            android:textColor="#333333"
            android:textSize="16sp" />
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

        <TextView
            android:id="@+id/menu_show_blood_banks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:text="Show All Blood Banks"
            android:textColor="#333333"
            android:textSize="16sp" />
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

        <TextView
            android:id="@+id/menu_show_hospitals"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:text="Show All Hospitals"
            android:textColor="#333333"
            android:textSize="16sp" />
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

        <TextView
            android:id="@+id/menu_manage_locations"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:text="Manage App Locations"
            android:textColor="#333333"
            android:textSize="16sp" />
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

        <TextView
            android:id="@+id/menu_active_requests"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:text="Active Requests"
            android:textColor="#333333"
            android:textSize="16sp" />
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

        <TextView
            android:id="@+id/menu_previous_requests"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:text="Previous Requests"
            android:textColor="#333333"
            android:textSize="16sp" />
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

        <TextView
            android:id="@+id/menu_logout_admin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:text="Logout"
            android:textColor="#D11A2A"
            android:textStyle="bold"
            android:textSize="16sp" />
    </LinearLayout>
</androidx.drawerlayout.widget.DrawerLayout>
