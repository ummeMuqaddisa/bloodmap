<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F2F2"
    android:fitsSystemWindows="true">

    <!-- Top Bar -->
    <RelativeLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#F2F2F2"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/back_button"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_arrow_back"
            android:padding="4dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            app:tint="#800000" />

        <TextView
            android:id="@+id/tvHospitalFormTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Edit Hospital"
            android:textColor="#800000"
            android:textSize="17sp"
            android:textStyle="bold" />

        <!-- Save icon on top right -->
        <ImageView
            android:id="@+id/ivSaveIcon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@android:drawable/checkbox_on_background"
            android:padding="4dp"
            app:tint="#800000"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackgroundBorderless" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/toolbar"
        android:clipToPadding="false"
        android:paddingBottom="100dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="16dp">

            <!-- General Information Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="General Information"
                        android:textColor="#1A1A1A"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="20dp" />

                    <!-- Hospital Name -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HOSPITAL NAME"
                        android:textColor="#800000"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"
                        android:layout_marginBottom="6dp" />
                    <EditText
                        android:id="@+id/etHospitalName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_field_input"
                        android:hint="Dhaka Medical College Hospital"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="14dp"
                        android:textColor="#1A1A1A"
                        android:textSize="15sp"
                        android:layout_marginBottom="16dp" />

                    <!-- Phone Number -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PHONE NUMBER"
                        android:textColor="#800000"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"
                        android:layout_marginBottom="6dp" />
                    <EditText
                        android:id="@+id/etHospitalPhone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_field_input"
                        android:hint="0255165130"
                        android:inputType="phone"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="14dp"
                        android:textColor="#1A1A1A"
                        android:textSize="15sp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Location Details Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Location Details"
                        android:textColor="#1A1A1A"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="20dp" />

                    <!-- Address -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ADDRESS"
                        android:textColor="#800000"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"
                        android:layout_marginBottom="6dp" />
                    <EditText
                        android:id="@+id/etHospitalAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_field_input"
                        android:hint="Secretariat Road, Shahbagh, Dhaka-1000"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="14dp"
                        android:textColor="#1A1A1A"
                        android:textSize="15sp"
                        android:minLines="2"
                        android:gravity="top|start"
                        android:layout_marginBottom="16dp" />

                    <!-- Lat & Lon row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginEnd="10dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="LATITUDE"
                                android:textColor="#800000"
                                android:textSize="9sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.05"
                                android:layout_marginBottom="6dp" />
                            <EditText
                                android:id="@+id/etLatitude"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_field_input"
                                android:hint="23.7261"
                                android:inputType="numberDecimal|numberSigned"
                                android:paddingHorizontal="14dp"
                                android:paddingVertical="14dp"
                                android:textColor="#1A1A1A"
                                android:textSize="15sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="LONGITUDE"
                                android:textColor="#800000"
                                android:textSize="9sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.05"
                                android:layout_marginBottom="6dp" />
                            <EditText
                                android:id="@+id/etLongitude"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_field_input"
                                android:hint="90.3976"
                                android:inputType="numberDecimal|numberSigned"
                                android:paddingHorizontal="14dp"
                                android:paddingVertical="14dp"
                                android:textColor="#1A1A1A"
                                android:textSize="15sp" />
                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Services & Facilities Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Services &amp; Facilities"
                        android:textColor="#1A1A1A"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="20dp" />

                    <!-- Facilities -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FACILITIES (COMMA SEPARATED)"
                        android:textColor="#800000"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"
                        android:layout_marginBottom="6dp" />
                    <EditText
                        android:id="@+id/etFacilities"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_field_input"
                        android:hint="ICU, Emergency, NICU"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="14dp"
                        android:textColor="#1A1A1A"
                        android:textSize="15sp"
                        android:layout_marginBottom="20dp" />

                    <!-- Blood Bank Switch -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:text="Has Blood Bank?"
                            android:textColor="#1A1A1A"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchBloodBank"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            app:useMaterialThemeColors="false"
                            app:thumbTint="#FFFFFF"
                            app:trackTint="#800000" />

                    </RelativeLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Save Button -->
            <Button
                android:id="@+id/btnSaveHospital"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:backgroundTint="#800000"
                android:text="Update Hospital Info"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="12dp"
                app:icon="@android:drawable/ic_menu_save"
                app:iconTint="#FFFFFF"
                app:iconGravity="textStart" />

        </LinearLayout>
    </ScrollView>

</RelativeLayout>
